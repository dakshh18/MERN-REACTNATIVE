# Firebase
# google-services.json and GoogleService-Info.plist are NOT secrets — Firebase
# explicitly says these client config files are safe to commit. We need them
# committed so EAS Build can package them into release APKs.
# google-services.json
GoogleService-Info.plist

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
