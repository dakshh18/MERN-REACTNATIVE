## ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DB_URL=mongodb://localhost:27017/mern-rn

## Comma-separated list of allowed origins for CORS (e.g. admin SPA / web app).
CLIENT_URL=http://localhost:5173

## ─── Clerk (existing OAuth — Google / Apple) ────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
INNGEST_SIGNING_KEY=

## ─── Cloudinary (product images) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

## Admin gate (email address that is allowed to hit /api/admin/*).
ADMIN_EMAIL=

## ─── Local email/password + OTP auth (NEW) ──────────────────────────────────
## HS256 secret for our own JWTs. Generate with:
##   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

## OTP lifetime, resend cooldown, and per-OTP attempt cap.
AUTH_OTP_EXPIRY_MINUTES=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_ATTEMPTS=5

## ─── Email OTP ──────────────────────────────────────────────────────────────
## Two providers ship out-of-the-box:
##   mailpit → plain-SMTP-no-auth client; pair with a local Mailpit instance.
##             Install:  https://mailpit.axllent.org/  (or `docker run -p 1025:1025 -p 8025:8025 axllent/mailpit`)
##             Inbox UI: http://localhost:8025
##   smtp    → nodemailer transport; works with Gmail / SES / Postmark / any real SMTP.
##
## Gmail App-Password recipe (free, takes 5 min):
##   1. Enable 2-Step Verification on the Google account.
##   2. https://myaccount.google.com/apppasswords → create one for "Mail".
##   3. Set EMAIL_PROVIDER=smtp and the SMTP_* values below.
EMAIL_PROVIDER=mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false        # true for port 465 (TLS-on-connect); false for 587 (STARTTLS)
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Your App <no-reply@local.test>"

## Production Gmail example (uncomment + replace):
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx        # 16-char app password, no spaces
# EMAIL_FROM="Mern Shop <your-account@gmail.com>"

## ─── SMS OTP ────────────────────────────────────────────────────────────────
## mock                → console.log only (recommended for learning / dev)
## android-sms-gateway → POST to a self-hosted https://github.com/capcom6/android-sms-gateway
##                       (needs an Android phone with SIM; carrier SMS charges still apply)
SMS_PROVIDER=mock
SMS_GATEWAY_BASE_URL=
SMS_GATEWAY_API_KEY=
